[Unit]
Description=paracoding human-confirmed privileged executor (runs ONLY confirm_work_item-approved items; agents cannot confirm - #159/#11). NOT the removed auto-jobrunner.
After=network.target paracoding-mcp.service

[Service]
Type=simple
User=root
ExecStart=/usr/bin/python3 /opt/paracoding-mcp/jobrunner/confirm_runner.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target